# Пример файла с переменными окружения
# Скопируйте этот файл в .env и заполните реальными значениями

# Timeweb Cloud API токен (обязательно)
TIMEWEB_CLOUD_TOKEN=your_timeweb_cloud_token_here

# Окружение по умолчанию (prod, stage, dev)
ENV=dev

# Network ID для VPC (можно переопределить из конфигурации)
NETWORK_ID=network-3654798e575f4dd3b9ad3e9dec940ead

# Project ID (можно переопределить из конфигурации)
PROJECT_ID=103757

# AWS S3 credentials (для работы с S3)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
